# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase pooler - session mode, IPv4 compatible)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Firecrawl
FIRECRAWL_API_KEY=fc-your-api-key
# Max concurrent browsers used per crawl job. Default 5 (matches Firecrawl
# hobby plan limit). Raise on larger plans, lower if you need headroom for
# ad-hoc screenshot/re-scrape calls while a crawl is running.
FIRECRAWL_MAX_CONCURRENCY=5

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Inngest
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key
